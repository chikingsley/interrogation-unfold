end

wait 2
show_character jen LEFT_CENTER normal_smile
show_character tab LEFT normal
show_character mordecai RIGHT proud
if has_joseph
  show_character joseph RIGHT_CENTER neutral
end
wait 1

mordecai: [thinking] ...mayor Patel's just way too hot. She has to be the Kiss!

tab: [listening] I'm confident in picking her for Marry.
animate mordecai proud

if has_joseph
  joseph: [concern] So, you're killing Damascus Reed? Seems like a waste of the many millions in his accounts?
  wait_for_input
  animate joseph neutral
else
