* I have to kiss Patricia Becker. She's a fit lady.
  kmk_patricia = "kiss"
  hide_bubbles
  animate jen normal_smile
  animate tab normal
  animate mordecai point
  mordecai_approval +5

* Kissing Tristan. He's a fit gentleman.
  kmk_tristan = "kiss"
  hide_bubbles
  animate jen normal_smile
  animate tab laugh
  animate mordecai proud

end

if has_joseph
  animate joseph neutral
end

choose
* [not kmk_chief] I'll marry Chief Anderson Seems like he'd be a good dad.
  kmk_chief = "marry"
  hide_bubbles
